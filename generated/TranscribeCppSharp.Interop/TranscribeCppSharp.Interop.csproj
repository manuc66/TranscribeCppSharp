<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <IsPackable>true</IsPackable>
    <PackageId>TranscribeCppSharp.Interop</PackageId>
    <Description>C# interop bindings for transcribe.cpp — native speech-to-text inference library</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/manuc66/TranscribeCppSharp</PackageProjectUrl>

    <WarningsAsErrors>
      SYSLIB1051;
      SYSLIB1054;
      SYSLIB1055;
    </WarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <Import Include="System.Runtime.InteropServices" />
    <InternalsVisibleTo Include="TranscribeCppSharp.Interop.Tests" />
    <InternalsVisibleTo Include="SmokeTest" />
    <InternalsVisibleTo Include="ScribeManIA" />
    <InternalsVisibleTo Include="TranscribeCppSharp" />
  </ItemGroup>

</Project>
